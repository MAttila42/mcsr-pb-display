{
  "name": "mcsr-pb-display-api",
  "packageManager": "bun@1.3.10",
  "module": "src/index.js",
  "scripts": {
    "dev": "wrangler dev --local src/index.ts --port 3000",
    "preview": "wrangler dev --remote src/index.ts --port 3000",
    "db": "drizzle-kit",
    "scan": "bun --bun run scripts/scan.ts",
    "r:db": "NODE_ENV=production drizzle-kit",
    "deploy": "wrangler deploy --minify src/index.ts"
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.1",
    "@rttnd/gau": "^1.4.3",
    "drizzle-orm": "^0.45.1"
  },
  "devDependencies": {
    "bun-types": "latest",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.21.0",
    "wrangler": "^4.73.0"
  },
  "overrides": {
    "@sinclair/typebox": "0.32.4"
  }
}
